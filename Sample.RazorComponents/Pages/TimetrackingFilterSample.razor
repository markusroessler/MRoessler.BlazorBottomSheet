@page "/timetracking-filter"
@using MRoessler.BlazorBottomSheet.Sample.RazorComponents.Layout

<PageTitle>BottomSheet: TimetrackingFilter</PageTitle>
<SectionContent SectionName="@MainLayout.AppBarHeaderName">TimetrackingFilter</SectionContent>

<MudPaper Class="pa-2" Style="height: 100%;">
    <MudStack>
        <MudButton OnClick="ToggleButtonSheetOpen" Variant="Variant.Filled" Color="Color.Primary" Class="mt-5" data-testid="open-close-button">Open/Close BottomSheet</MudButton>
    </MudStack>
</MudPaper>

<BottomSheet DefaultExpansion="BottomSheetExpansion.Normal" AllowMinimizedExpansion AllowMaximizedExpansion @bind-IsOpen="_isOpen" Class="mud-bottom-sheet" IsModal CloseOnBackgroundClick>
    <MudGrid Spacing="2" Class="mb-5">
        <MudItem xs="12">
        <MudText Typo="Typo.h5">Filter</MudText>
            <MinimizedExpansionMarker />
        </MudItem>

        <MudItem xs="4">
            <MudAutocomplete @bind-Value="_year" SearchFunc="SearchYearAsync" Variant="Variant.Outlined" Label="Year" InputMode="InputMode.numeric" />
        </MudItem>

        <MudItem xs="6">
            <MudAutocomplete @bind-Value="_month" SearchFunc="SearchMonthAsync" Variant="Variant.Outlined" Label="Month" />
        </MudItem>

        <MudItem xs="12">
            <MudChipSet @bind-SelectedValues="_selectedChips" SelectionMode="SelectionMode.MultiSelection" CheckMark Variant="Variant.Text" Color="Color.Info">
                <MudChip Value="@("Holiday")" />
                <MudChip Value="@("Vacation")" />
                <MudChip Value="@("Sickness")" />
            </MudChipSet>
        </MudItem>

        <MudItem xs="12">
            <MudSwitch @bind-Value="_overdue" Label="Overdue" />
        </MudItem>

        <MudItem xs="12">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth OnClick="ApplyAsync">Apply</MudButton>
        </MudItem>

        <MudItem xs="12">
            <MudButton Variant="Variant.Text" Color="Color.Primary" FullWidth OnClick="ResetAsync">Reset</MudButton>
        </MudItem>

        <MudItem xs="12">
            <NormalExpansionMarker />
        </MudItem>
    </MudGrid>
</BottomSheet>