            <!-- <DEVICE_NAME>Desktop Chrome</DEVICE_NAME> -->
        </EnvironmentVariables>
    </RunConfiguration>

    <Playwright>
        <BrowserName>chromium</BrowserName>
        <!-- <BrowserName>webkit</BrowserName> -->
        <!-- <BrowserName>firefox</BrowserName> -->
        <LaunchOptions>
            <!-- <Headless>false</Headless> -->
            <!-- <SlowMo>200</SlowMo> -->
        </LaunchOptions>
    </Playwright>
</RunSettings>